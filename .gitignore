# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Data directories.
#
# Most of `data_raw/` is gitignored — it's bulky (~150 MB ACS JSON cache,
# ~200 MB Census archives, etc.) and refreshable from URLs. We DO commit
# the small foundational sources (~10 MB total) inline so the project can
# be reproduced even if upstream URLs change. Plus the MANIFEST.toml,
# which records SHA-256 + size + source URL for EVERY file under
# data_raw/ regardless of whether it's tracked.
data_raw/*
!data_raw/MANIFEST.toml
!data_raw/cdc/
!data_raw/cornell/
!data_raw/nchs/
!data_raw/nysdol/

# Interim and final outputs — regenerable from data_raw/ via the notebooks.
data_interim/
data_final/

# Git worktree for the docs/main branch (docs editing from any feature
# branch; docs changes merge to main via PR/merge like code does).
.worktree-docs/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Build artifacts
build/
dist/
